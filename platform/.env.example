# Local dev: docker compose up -d db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/growthmonk

# Engine adapters (read-only sampling)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Raw engine responses (Phase A: local dir; object-storage seam later)
RAW_STORE_DIR=./raw

# WhatsApp Business (Meta Cloud API) — attribution spine
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=
WABA_VERIFY_TOKEN=
WABA_APP_SECRET=

# DataForSEO (SERP/keywords/labs)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Content engine (local serp-analyzer service)
CONTENT_ENGINE_URL=

# Optional
GM_WORKER_ID=
ADMIN_TOKEN=
INDEXNOW_KEY=
